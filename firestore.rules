rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Connection Test Document
    match /test/connection {
      allow read: if true;
    }

    // --- ENTITY VALIDATORS ---
    
    function isValidRequest(data) {
      return data.victimName is string && data.victimName.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.status in ['pending', 'assigned', 'dispatched', 'completed', 'cancelled']
        && data.location.lat is number
        && data.location.lng is number
        && data.location.address is string && data.location.address.size() <= 500
        && data.keys().hasAll(['victimName', 'phone', 'status', 'location', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 6;
    }

    function isValidObstacle(data) {
      return data.lat is number && data.lng is number
        && data.type is string && data.type.size() <= 100
        && data.keys().hasAll(['lat', 'lng', 'type', 'createdAt'])
        && data.keys().size() >= 4;
    }

    function isValidDelivery(data) {
      return data.requestId is string && isValidId(data.requestId)
        && data.status in ['en-route', 'arrived', 'delivered']
        && data.currentLocation.lat is number
        && data.currentLocation.lng is number
        && data.keys().hasAll(['requestId', 'status', 'currentLocation', 'updatedAt'])
        && data.keys().size() >= 4;
    }

    // --- COLLECTION RULES ---

    match /requests/{requestId} {
      allow read: if true; 
      allow create: if isValidRequest(incoming())
                   && (incoming().createdAt == request.time || incoming().createdAt is timestamp)
                   && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp);
      
      allow update: if isValidRequest(incoming())
                   && (
                     // Action: NGO Assigns or Updates Status
                     incoming().diff(existing()).affectedKeys().hasAll(['status', 'updatedAt'])
                     || incoming().diff(existing()).affectedKeys().hasOnly(['ngoReply', 'updatedAt'])
                   )
                   && incoming().updatedAt == request.time;
      
      allow delete: if false; 
    }

    match /deliveries/{deliveryId} {
      allow read: if true;
      allow create: if isValidDelivery(incoming()) && incoming().updatedAt == request.time;
      allow update: if isValidDelivery(incoming()) 
                   && (incoming().updatedAt == request.time)
                   && incoming().diff(existing()).affectedKeys().hasOnly(['currentLocation', 'status', 'updatedAt']);
    }

    match /obstacles/{obstacleId} {
      allow read: if true;
      allow create: if isValidObstacle(incoming()) && incoming().createdAt == request.time;
      allow update: if false; // Obstacles are immutable once reported
    }

    match /ngos/{ngoId} {
      allow read: if true;
      allow write: if false; 
    }
  }
}
